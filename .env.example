# ══════════════════════════════════════════════════════════════════════
# SENTRA Gateway — Environment Variables Template
# Copy this file to .env and fill in all required values.
# NEVER commit .env to git — it is listed in .gitignore.
# ══════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Security ──────────────────────────────────────────────────────────
# Your Sentra master API key (used for SDK auth header validation)
API_KEY=your_sentra_api_key_here

# [CVE-2] JWT secret — REQUIRED, minimum 32 characters
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_strong_secret_of_at_least_32_chars

# CORS — comma-separated list of allowed origins in production
CORS_ORIGIN=http://localhost:3000

# ── Nokia Network-as-Code API ─────────────────────────────────────────
NOKIA_API_KEY=your_nokia_api_key_here
NOKIA_ENV=dev
NOKIA_BASE_URL=https://sandbox.api.nokia-as-code.com

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url_here
# Use the service_role key for server-to-server — NEVER the anon key in production
SUPABASE_KEY=your_supabase_service_role_key_here

# ── Webhooks (optional, HTTPS only in production) ─────────────────────
# Leave empty to disable. Must use HTTPS URLs — HTTP and private IPs are rejected.
WEBHOOK_TRUST_ALERT_URL=
WEBHOOK_TRANSACTION_BLOCKED_URL=
WEBHOOK_TRANSACTION_STEP_UP_URL=
WEBHOOK_ESCROW_CREATED_URL=
WEBHOOK_ESCROW_RELEASED_URL=
