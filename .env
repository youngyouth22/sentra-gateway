# Server
PORT=3000
NODE_ENV=development

# API Keys
API_KEY=your-api-key-here

# [CVE-2 FIX] JWT_SECRET is now required — generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_replace_with_a_strong_randomly_generated_secret_of_at_least_32_characters

# Nokia as Code Sandbox
NOKIA_API_KEY=5fb26c2523mshac7481a291f093bp1fb3dcjsn0ee57fb5d543
NOKIA_BASE_URL=https://sandbox.api.nokia-as-code.com

# Logging
LOG_LEVEL=info

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
